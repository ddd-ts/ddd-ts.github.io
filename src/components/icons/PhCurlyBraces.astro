---
interface Props {
  class?: string;
  size?: number | string;
}

const { class: className, size = "1em" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 256 256"
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
>
  <path
    d="M80,40c-64,0,0,88-64,88,64,0,0,88,64,88"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="16"></path>
  <path
    d="M176,40c64,0,0,88,64,88-64,0,0,88-64,88"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="16"></path>
</svg>
