---
interface Props {
  class?: string;
  size?: number | string;
}

const { class: className, size = "1em" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 256 256"
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
>
  <path
    d="M128,88a32,32,0,0,1,32-32h72V200H160a32,32,0,0,0-32,32"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="16"></path>
  <path
    d="M24,200H96a32,32,0,0,1,32,32V88A32,32,0,0,0,96,56H24Z"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="16"></path>
</svg>
